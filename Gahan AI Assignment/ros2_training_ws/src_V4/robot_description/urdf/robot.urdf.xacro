<?xml version="1.0"?>
<robot name="diff_drive_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ===================================================================
       PROPERTIES  — single source of truth for all geometry
       =================================================================== -->
  <xacro:property name="wheel_radius"  value="0.05"/>
  <xacro:property name="wheel_width"   value="0.02"/>
  <xacro:property name="base_length"   value="0.30"/>
  <xacro:property name="base_width"    value="0.25"/>
  <xacro:property name="base_height"   value="0.12"/>
  <xacro:property name="caster_radius" value="0.025"/>

  <!-- ===================================================================
       MATERIALS
       =================================================================== -->
  <material name="blue">  <color rgba="0.0 0.0 0.8 1.0"/> </material>
  <material name="black"> <color rgba="0.0 0.0 0.0 1.0"/> </material>
  <material name="grey">  <color rgba="0.5 0.5 0.5 1.0"/> </material>
  <material name="red">   <color rgba="0.8 0.0 0.0 1.0"/> </material>
  <material name="white"> <color rgba="0.9 0.9 0.9 1.0"/> </material>

  <!-- ===================================================================
       BASE FOOTPRINT  — sits exactly on the ground plane (z = 0)
       =================================================================== -->
  <link name="base_footprint"/>

  <!-- base_link origin is at ground level (same as base_footprint).
       The chassis visual/collision is raised inside base_link so the
       bottom of the box sits at wheel_radius above the ground. -->
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ===================================================================
       BASE LINK  — chassis box
       Visual/collision origin raised so bottom of box = wheel_radius.
       Centre of box = wheel_radius + base_height/2
       =================================================================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${wheel_radius + base_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${wheel_radius + base_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <!-- Inertia tensor for a solid box: m=5 kg -->
      <origin xyz="0 0 ${wheel_radius + base_height/2}" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia
        ixx="${(1.0/12.0)*5.0*(base_width*base_width + base_height*base_height)}"
        ixy="0.0" ixz="0.0"
        iyy="${(1.0/12.0)*5.0*(base_length*base_length + base_height*base_height)}"
        iyz="0.0"
        izz="${(1.0/12.0)*5.0*(base_length*base_length + base_width*base_width)}"/>
    </inertial>
  </link>

  <!-- ===================================================================
       LEFT WHEEL
       Joint origin: axle centre is at (0, +base_width/2, wheel_radius).
       Cylinder default axis is Z; rpy="1.5707 0 0" rotates it to align
       with the Y axis (the wheel axle direction).
       =================================================================== -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <!-- Solid cylinder: m=0.5 kg -->
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia
        ixx="${(1.0/12.0)*0.5*(3.0*wheel_radius*wheel_radius + wheel_width*wheel_width)}"
        ixy="0.0" ixz="0.0"
        iyy="${(1.0/12.0)*0.5*(3.0*wheel_radius*wheel_radius + wheel_width*wheel_width)}"
        iyz="0.0"
        izz="${0.5*0.5*wheel_radius*wheel_radius}"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel"/>
    <!-- Axle centre: centred fore-aft, offset to left side, at wheel_radius height -->
    <origin xyz="0 ${base_width/2} ${wheel_radius}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ===================================================================
       RIGHT WHEEL
       =================================================================== -->
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia
        ixx="${(1.0/12.0)*0.5*(3.0*wheel_radius*wheel_radius + wheel_width*wheel_width)}"
        ixy="0.0" ixz="0.0"
        iyy="${(1.0/12.0)*0.5*(3.0*wheel_radius*wheel_radius + wheel_width*wheel_width)}"
        iyz="0.0"
        izz="${0.5*0.5*wheel_radius*wheel_radius}"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel"/>
    <!-- Mirror of left: offset to right side -->
    <origin xyz="0 -${base_width/2} ${wheel_radius}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ===================================================================
       FRONT CASTER  — passive sphere, slightly below chassis bottom
       =================================================================== -->
  <link name="caster_front">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${caster_radius}"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${caster_radius}"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia
        ixx="${(2.0/5.0)*0.1*caster_radius*caster_radius}"
        ixy="0.0" ixz="0.0"
        iyy="${(2.0/5.0)*0.1*caster_radius*caster_radius}"
        iyz="0.0"
        izz="${(2.0/5.0)*0.1*caster_radius*caster_radius}"/>
    </inertial>
  </link>

  <joint name="caster_front_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_front"/>
    <origin xyz="${base_length/2 - 0.05} 0 ${wheel_radius/2}" rpy="0 0 0"/>
  </joint>

  <!-- ===================================================================
       REAR CASTER
       =================================================================== -->
  <link name="caster_rear">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${caster_radius}"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${caster_radius}"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia
        ixx="${(2.0/5.0)*0.1*caster_radius*caster_radius}"
        ixy="0.0" ixz="0.0"
        iyy="${(2.0/5.0)*0.1*caster_radius*caster_radius}"
        iyz="0.0"
        izz="${(2.0/5.0)*0.1*caster_radius*caster_radius}"/>
    </inertial>
  </link>

  <joint name="caster_rear_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_rear"/>
    <origin xyz="-${base_length/2 + 0.05} 0 ${wheel_radius/2}" rpy="0 0 0"/>
  </joint>

  <!-- ===================================================================
       IMU LINK  — mounted on top of chassis
       =================================================================== -->
  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.02"/></geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0.0" ixz="0.0"
               iyy="0.000001" iyz="0.0"
               izz="0.000001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <!-- Top surface of chassis -->
    <origin xyz="0 0 ${wheel_radius + base_height}" rpy="0 0 0"/>
  </joint>

  <!-- ===================================================================
       LIDAR LINK  — mounted on top of chassis, above IMU
       =================================================================== -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.06"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.06"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.000043" ixy="0.0" ixz="0.0"
               iyy="0.000043" iyz="0.0"
               izz="0.000080"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <!-- 3 cm above top of chassis -->
    <origin xyz="0 0 ${wheel_radius + base_height + 0.03}" rpy="0 0 0"/>
  </joint>

  <!-- ===================================================================
       GAZEBO PLUGINS
       =================================================================== -->

  <!-- Differential drive controller
       wheel_separation = base_width  (distance between wheel centres)
       wheel_diameter   = 2 * wheel_radius                              -->
  <gazebo>
    <plugin name="diff_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <!-- Must match URDF geometry exactly -->
      <wheel_separation>${base_width}</wheel_separation>
      <wheel_diameter>${2 * wheel_radius}</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <!-- Nav2 convention: odom → base_link -->
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
  </gazebo>

  <!-- IMU sensor plugin — publishes to /imu -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <visualize>true</visualize>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=imu</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
    </sensor>
  </gazebo>

  <!-- LIDAR sensor plugin — publishes to /scan -->
  <gazebo reference="lidar_link">
    <sensor name="lidar_sensor" type="ray">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin filename="libgazebo_ros_ray_sensor.so" name="lidar_plugin">
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Caster friction = 0 so they slide freely without fighting the drive wheels -->
  <gazebo reference="caster_front">
    <material>Gazebo/Grey</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <gazebo reference="caster_rear">
    <material>Gazebo/Grey</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <!-- Colours in Gazebo -->
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo reference="left_wheel">
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="right_wheel">
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="imu_link">
    <material>Gazebo/Red</material>
  </gazebo>
  <gazebo reference="lidar_link">
    <material>Gazebo/Grey</material>
  </gazebo>

</robot>
